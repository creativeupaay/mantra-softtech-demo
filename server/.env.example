# Voice Agent - Environment Variables
# Copy this file to .env and fill in your API keys


# Deepgram (STT/TTS)
DEEPGRAM_API_KEY=

# TTS Provider Configuration
# Comma-separated list in priority order
# Options: sarvam, elevenlabs, cartesia, deepgram
TTS_PROVIDER_ORDER=sarvam,elevenlabs,cartesia,deepgram

# Sarvam AI (Best for Indian languages - Hindi, Hinglish)
SARVAM_API_KEY=

# ElevenLabs (High quality, supports multilingual)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Cartesia (Fast, multilingual)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# Google (LLM)
GOOGLE_API_KEY=
GOOGLE_MODEL=

# ─── RAG / Knowledge Base ─────────────────────────────────────────

# Qdrant (Vector DB - runs on Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=mantra_knowledge

# Embedding Model (fastembed - runs locally via ONNX, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG Search Config
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
